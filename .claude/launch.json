{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "catalogo",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/catalogo"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "sitio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/sitio"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "admin",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/admin"],
      "port": 3002,
      "autoPort": true
    },
    {
      "name": "linktree",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "linktree/public", "-l", "3003"],
      "port": 3003,
      "autoPort": true
    }
  ]
}
