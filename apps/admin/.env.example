# apps/admin — variables de entorno (copiar a .env.local y rellenar)

# ── Firebase Web SDK (login, Fase 6 / ADR-0029) ──────────────────────────────
# Config del cliente para Firebase Authentication (email/password). Estos
# valores son PÚBLICOS por diseño (viajan en el JS del navegador; no son
# secretos, a diferencia de una API key de servidor) — se pueden versionar sin
# riesgo una vez rellenados. El scaffold (#138) solo documenta los nombres; el
# paquete `firebase` y el código de inicialización/login llegan en #139.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
