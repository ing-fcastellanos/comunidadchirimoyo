# apps/admin — variables de entorno (copiar a .env.local y rellenar)

# ── Firebase Web SDK (login, Fase 6 / ADR-0029) ──────────────────────────────
# Config del cliente para Firebase Authentication (email/password). Estos
# valores son PÚBLICOS por diseño (viajan en el JS del navegador; no son
# secretos, a diferencia de una API key de servidor) — se pueden versionar sin
# riesgo una vez rellenados.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firestore: contenido dinámico (mismo patrón que apps/sitio, Fase 6) ──────
# Necesario en cuanto #140/#141 agreguen CRUD; el login (#139) no lo usa.
GOOGLE_CLOUD_PROJECT=chirimoyo

# ── DEV LOCAL: emulators de Firebase (login + Firestore futuro) ──────────────
# Arranca ambos desde services/api:
#   firebase emulators:start --only auth,firestore --project chirimoyo
# El Admin SDK detecta FIREBASE_AUTH_EMULATOR_HOST automáticamente (sin código
# extra); el Web SDK del cliente necesita el equivalente NEXT_PUBLIC_ (ver
# lib/firebase-client.ts, connectAuthEmulator). PROD: no definas ninguna de las
# dos — ADC/el proyecto real toman el control (requiere roles/iam.serviceAccountTokenCreator,
# ver README.md).
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8085
