# apps/sitio — variables de entorno (copiar a .env.local y rellenar)

# ── Analítica web (Cloudflare Web Analytics, ADR-0020) ───────────────────────
# Sin cookies, sin PII, sin banner. Seguimiento POR DOMINIO: un "site"/token
# de Cloudflare por dominio. Si esta variable falta, la analítica se desactiva
# sin romper la app.

# Mapa JSON host -> token del beacon de Cloudflare (en una sola línea).
# Tras ADR-0023, `sitio` sirve un único dominio (`chirimoyo.org`); `comunidad.*` y
# `voluntarios.*` son redirects vanity 301, no renderizan la app, así que no llevan
# token. Pega el token del "site" de Cloudflare de chirimoyo.org.
NEXT_PUBLIC_CF_BEACON_TOKENS={"chirimoyo.org":""}

# ── API de contacto (services/api) ───────────────────────────────────────────
# URL base del API. SOLO server-side (NO NEXT_PUBLIC): el formulario de contacto
# envía vía Server Action, que reenvía a `${API_URL}/api/contacto`. El navegador
# nunca ve esta URL. En local apunta al Flask de services/api; en prod, al Cloud
# Run del API. Si falta, usa http://localhost:8080.
API_URL=http://localhost:8080
