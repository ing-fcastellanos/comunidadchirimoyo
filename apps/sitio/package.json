{
  "name": "sitio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sync:tokens": "node ../../scripts/sync-design-tokens.mjs",
    "docker:build": "docker build -t northamerica-south1-docker.pkg.dev/chirimoyo/containers/sitio:latest .",
    "docker:push": "docker push northamerica-south1-docker.pkg.dev/chirimoyo/containers/sitio:latest",
    "deploy_run": "npm run docker:build && npm run docker:push && gcloud run deploy sitio --image=northamerica-south1-docker.pkg.dev/chirimoyo/containers/sitio:latest --project=chirimoyo --region=us-central1 --platform=managed --allow-unauthenticated --min-instances=0 --port=8080",
    "firebase:deploy": "firebase deploy --only hosting --project=chirimoyo",
    "deploy_prod": "npm run deploy_run && npm run firebase:deploy"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
