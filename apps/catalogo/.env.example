# apps/catalogo — variables de entorno (copiar a .env.local y rellenar)
#
# OJO: el catálogo es export estático (output: "export"). Las NEXT_PUBLIC_*
# se inyectan en BUILD (`next build`), no en runtime: deben estar presentes
# en el entorno que ejecuta `npm run deploy_prod`.

# ── Analítica web (Cloudflare Web Analytics, ADR-0020) ───────────────────────
# Sin cookies, sin PII, sin banner. Seguimiento POR DOMINIO: un "site"/token
# de Cloudflare por dominio. Si esta variable falta en el build, la analítica
# se desactiva sin romper la app.

# Mapa JSON host -> token del beacon de Cloudflare (en una sola línea).
# `catalogo` sirve un solo dominio.
NEXT_PUBLIC_CF_BEACON_TOKENS={"aves.chirimoyo.org":""}
