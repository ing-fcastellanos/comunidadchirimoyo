{
  "name": "catalogo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:pdf && next build",
    "build:pdf:css": "tailwindcss -i ./print/print.css -o ./print/_print.generated.css --minify",
    "build:pdf": "npm run build:pdf:css && tsx ./scripts/build-pdf.mts",
    "photo:tool": "tsx ./scripts/build-photo-tool.mts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sync:tokens": "node ../../scripts/sync-design-tokens.mjs",
    "firebase:deploy:prod": "firebase deploy --only hosting:prod --project=chirimoyo",
    "deploy_prod": "npm run build && npm run firebase:deploy:prod"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "playwright": "^1.49.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "@types/qrcode": "^1.5.5"
  }
}
