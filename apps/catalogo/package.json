{
  "name": "catalogo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pdf:css": "tailwindcss -i ./print/print.css -o ./print/_print.generated.css --minify",
    "build:pdf": "npm run build:pdf:css && tsx ./scripts/build-pdf.mts",
    "photo:tool": "tsx ./scripts/build-photo-tool.mts",
    "validate:fichas": "tsx ./scripts/validar-fichas.mts",
    "smoke": "tsx ./scripts/smoke-fauna.mts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sync:tokens": "node ../../scripts/sync-design-tokens.mjs",
    "firebase:deploy:prod": "firebase deploy --only hosting:prod --project=chirimoyo",
    "deploy_prod": "npm run validate:fichas && npm run build:pdf && npm run build && npm run smoke && npm run firebase:deploy:prod"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "playwright": "^1.49.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "@types/qrcode": "^1.5.5"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "comments": {
    "engines": "Toolchain fijo (Node 24, ver .nvmrc y ADR-0022); engine-strict en .npmrc lo hace obligatorio para que el lockfile sea reproducible entre máquinas y CI.",
    "overrides": "Endurecimiento extra: fija las deps wasm opcionales/transitivas de @emnapi (fallback de eslint/tailwind/sharp, no usadas con bindings nativos), un punto conocido de no-determinismo en lockfiles npm."
  },
  "overrides": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2"
  }
}
